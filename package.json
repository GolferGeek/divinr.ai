{
  "name": "divinr-ai",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "build": "turbo run build",
    "ci:compliance": "pnpm -w run test:compliance",
    "ci:full-markets": "pnpm -w run ci:compliance && pnpm -w run ci:markets",
    "ci:markets": "pnpm -w run test:markets && pnpm --filter @divinr/api run test:markets:stages-v2 && pnpm -w run verify:markets",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:compliance": "turbo run test:compliance",
    "test:markets": "turbo run test:markets",
    "e2e": "pnpm --filter @divinr/e2e run e2e",
    "restart": "bash scripts/ops/restart.sh",
    "spark:restart": "bash scripts/ops/spark-restart.sh",
    "spark:deploy": "bash scripts/ops/spark-deploy.sh",
    "verify:markets": "node scripts/verify-markets-readiness.mjs",
    "typecheck": "turbo run typecheck"
  },
  "pnpm": {
    "overrides": {
      "@nestjs/common": "11.1.18",
      "@nestjs/core": "11.1.18",
      "@nestjs/config": "4.0.3"
    }
  },
  "devDependencies": {
    "turbo": "latest",
    "typescript": "latest",
    "eslint": "latest",
    "@typescript-eslint/eslint-plugin": "latest",
    "@typescript-eslint/parser": "latest"
  }
}
