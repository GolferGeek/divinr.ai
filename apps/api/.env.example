# apps/api/.env.example — Stripe & billing env vars introduced by stripe-integration effort.
#
# This file is documentation only. Real values live in the project-root .env (gitignored).
# Append the Stripe block below to your local .env after running `tsx apps/api/scripts/stripe-seed.ts`.

# --- Pricing (USD; the seed script multiplies × 100 to set Stripe Price unit_amount) ---
BASIC_MONTHLY_USD=50
INSTRUMENT_AUTHORSHIP_USD=20
ANALYST_AUTHORSHIP_USD=60
BYO_PLATFORM_FEE_USD=10
STUDENT_DISCOUNT_PCT=10
TRIAL_DAYS=30
DORMANCY_MONTHS_BEFORE_PURGE=6

# --- Stripe credentials ---
# sk_test_* for test mode, sk_live_* for prod. Never commit real keys.
STRIPE_SECRET_KEY=
# pk_test_* / pk_live_*. Surfaced to the SPA via GET /api/config/public.
STRIPE_PUBLISHABLE_KEY=
# whsec_*. One per environment. Local dev uses the value printed by `stripe listen`.
STRIPE_WEBHOOK_SECRET=
# Pinned Stripe API version. Bump intentionally as a focused effort.
STRIPE_API_VERSION=2025-04-30.basil

# --- Stripe Products + Prices (written by stripe-seed.ts) ---
STRIPE_PRODUCT_BASIC=
STRIPE_PRICE_BASIC_MONTHLY=
STRIPE_PRODUCT_INSTRUMENT=
STRIPE_PRICE_INSTRUMENT_REGULAR=
STRIPE_PRICE_INSTRUMENT_STUDENT=
STRIPE_PRODUCT_ANALYST=
STRIPE_PRICE_ANALYST_REGULAR=
STRIPE_PRICE_ANALYST_STUDENT=
STRIPE_PRODUCT_BYO=
STRIPE_PRICE_BYO_PLATFORM_FEE=

# --- Student .edu verification ---
# Comma-separated email domain suffixes. `edu` is conservative; add `.ac.uk` etc. per request.
STUDENT_EDU_ALLOWED_DOMAINS=edu
