# Base URLs
BASE_URL=https://divinr.ai
API_BASE_URL=https://api.divinr.ai

# Test user credentials — created by 2026-04-19-testing-team-seed.sql migration
TEST_USER_EMAIL=testing-team@divinr.ai
TEST_USER_PASSWORD=change-me

# Cloudflare Access (only needed if CF Access gating is enabled; per Phase 0 readiness, currently not required)
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# Playwright storage-state file (prepare-auth script writes to apps/e2e/.auth/testing-team.json)
PLAYWRIGHT_STORAGE_STATE=apps/e2e/.auth/testing-team.json
