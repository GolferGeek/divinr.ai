# Divinr local development environment.
# Copy to `.env` at the repository root. Leave optional credentials blank unless
# you are enabling that integration.

# --- Ports / URLs ---
PORT=7100
API_PORT=7100
VITE_API_PORT=7100
VITE_WEB_PORT=7101
CORS_ORIGINS=http://localhost:7101
APP_URL=http://localhost:7101
FRONTEND_URL=http://localhost:7101
BASE_URL=http://localhost:7101
API_BASE_URL=http://localhost:7100

# --- Local auth bootstrap ---
# Used by the Vite app to auto-login during local development.
VITE_DEFAULT_USER_EMAIL=demo-user@orchestratorai.io
VITE_DEFAULT_USER_PASSWORD=DemoUser123!
DIVINR_BUILDER_INVITER_EMAILS=

# --- Database ---
# `postgresql` is the normal local choice with docker-compose Postgres.
# `supabase` / `supabase_pg` use SUPABASE_* values instead.
DB_PROVIDER=postgresql
CONFIG_PROVIDER=env
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/divinr_ai

# Optional Supabase mode. Local defaults exist for SUPABASE_URL and service key,
# but set all three when connecting to hosted Supabase.
SUPABASE_URL=http://127.0.0.1:6010
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_MODE=local
SUPABASE_LOCAL_URL=http://127.0.0.1:6010
SUPABASE_LOCAL_SERVICE_ROLE_KEY=

# Optional Supabase CLI/config integrations.
SUPABASE_AUTH_SMS_TWILIO_AUTH_TOKEN=
SUPABASE_AUTH_EXTERNAL_APPLE_SECRET=
SENDGRID_API_KEY=
S3_HOST=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
SECRET_VALUE=

# Optional explicit env file path for packages that load dotenv themselves.
ENV_FILE=.env

# --- Development gates ---
NODE_ENV=development
MARKETS_DEV_AUTH_BYPASS=true
MARKETS_ENABLE_LLM=false
PHASE1_ENABLE_LLM=false
MARKETS_ENABLE_PIPELINE=false
MARKETS_ENABLE_MONTHLY_RESET=false
MARKETS_EXTERNAL_SYNC_ENABLED=false
MARKETS_EXTERNAL_SYNC_ORG_SLUG=

# Disable background jobs by default for predictable local startup.
MARKETS_DISABLE_CRAWLING=true
MARKETS_DISABLE_PREDICTOR_GENERATION=true
MARKETS_DISABLE_PREDICTION_GENERATION=true
MARKETS_DISABLE_OUTCOME_TRACKING=true
MARKETS_DISABLE_EOD_SETTLEMENT=true
MARKETS_DISABLE_NIGHTLY_CRON=true
MARKETS_DISABLE_BENCHMARK_INGEST=true
MARKETS_DISABLE_COORDINATION_CRON=true
MARKETS_DISABLE_RANK_SNAPSHOTS=true
MARKETS_DISABLE_CLUB_RANKINGS=true
MARKETS_DISABLE_TOURNAMENT_LIFECYCLE=true
DAY_TRADER_DISABLE_CRON=true
BILLING_DISABLE_LIFECYCLE_CRON=true
ATTRIBUTION_DISABLE_NIGHTLY_REFRESH=true

# --- Market analysis tuning ---
MARKETS_SIGNAL_THRESHOLD=1.5
MARKETS_URGENT_RELEVANCE=0.75
MARKETS_MAX_RUN_AGE_MINUTES=60
MARKETS_PREDICTOR_TTL_HOURS=48
MARKETS_RISK_BATCH_LIMIT=50
DASHBOARD_SIGNAL_MIN_CONFIDENCE=70
CONVICTION_TRADE_THRESHOLD=
ARBITRATOR_PORTFOLIO_ID=pf-portfolio-arbitrator
DAY_TRADER_CRON=0 14,17,20 * * 1-5
DAY_TRADER_EOD_CRON=55 20 * * 1-5
DAY_TRADER_IGNORE_MARKET_HOURS=false
TIER3_CRON=0 4 * * 0

# --- LLM routing ---
LLM_PROVIDER=ollama_local
OPENSOURCE_LLM_PROVIDER=ollama_local
COMMERCIAL_LLM_PROVIDER=openrouter
DEFAULT_LLM_PROVIDER=ollama
DEFAULT_LLM_MODEL=qwen3:8b
DEFAULT_OPENSOURCE_MODEL=qwen3:8b
DEFAULT_COMMERCIAL_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LOCAL_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen3:8b
LM_STUDIO_URL=http://localhost:1234
MARKETS_ALLOW_COMMERCIAL_FALLBACK=false
SIMPLIFIED_LLM_ROUTING=true
SKIP_OLLAMA_SYNC=false
MAX_MODEL_MEMORY_GB=8
ENABLE_VERBOSE_LOGGING=false

# Optional LLM/API provider credentials.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=http://localhost:7101
OPENROUTER_SITE_NAME=Divinr Local
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_BASE_URL=
GOOGLE_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=
XAI_API_KEY=
AZURE_AI_FOUNDRY_ENDPOINT=
AZURE_AI_FOUNDRY_KEY=
GCP_PROJECT_ID=
GCP_REGION=

# Optional tracing / observability.
OBSERVABILITY_PROVIDER=supabase
OBSERVABILITY_SINK_PROVIDER=supabase
OBSERVABILITY_EVENT_BUFFER=500
ALERT_ERROR_RATE=0.05
ALERT_RESPONSE_TIME_MS=30000
ALERT_MEMORY_USAGE=0.9
ALERT_CONSECUTIVE_FAILURES=3
ALERT_UNAVAILABLE_TIME_MS=60000
LANGSMITH_ENABLED=false
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=
LANGSMITH_PROJECT=divinr-local
LANGSMITH_PROJECT_NAME=divinr-local
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_ENDPOINT=
LANGCHAIN_PROJECT=divinr-local

# Optional market data / crawling integrations.
FIRECRAWL_API_KEY=
TWELVE_DATA_API_KEY=
POLYGON_API_KEY=
POLYGON_RATE_LIMIT_PER_MINUTE=5
FMP_API_KEY=
FINNHUB_API_KEY=
FRED_API_KEY=
ORCHESTRATOR_DATABASE_URL=
INSTRUMENT_CONTRACT_MODEL=

# --- Billing / Stripe ---
# Leaving STRIPE_SECRET_KEY blank disables Stripe paths and skips the local
# webhook listener in `pnpm --filter @divinr/api run dev:up`.
BASIC_MONTHLY_USD=50
INSTRUMENT_AUTHORSHIP_USD=20
ANALYST_AUTHORSHIP_USD=60
CONTRACT_OVERRIDE_USD=0
BYO_PLATFORM_FEE_USD=10
STUDENT_DISCOUNT_PCT=10
TRIAL_DAYS=30
DORMANCY_MONTHS_BEFORE_PURGE=6
STUDENT_EDU_ALLOWED_DOMAINS=edu
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_VERSION=2025-04-30.basil
STRIPE_PRODUCT_BASIC=
STRIPE_PRICE_BASIC_MONTHLY=
STRIPE_PRODUCT_INSTRUMENT=
STRIPE_PRICE_INSTRUMENT_REGULAR=
STRIPE_PRICE_INSTRUMENT_STUDENT=
STRIPE_PRODUCT_ANALYST=
STRIPE_PRICE_ANALYST_REGULAR=
STRIPE_PRICE_ANALYST_STUDENT=
STRIPE_PRODUCT_BYO=
STRIPE_PRICE_BYO_PLATFORM_FEE=

# --- Learning panel ---
LEARNING_PANEL_ENABLED=true
LEARNING_PANEL_MODEL_PROVIDER=
LEARNING_PANEL_MODEL_NAME=
LEARNING_PANEL_MONTHLY_CALL_LIMIT=200
LEARNING_PANEL_MONTHLY_COST_LIMIT_CENTS=500
LEARNING_PANEL_WARNING_THRESHOLD_RATIO=0.8
LEARNING_PANEL_MAX_INPUT_CHARS=4000
LEARNING_PANEL_MAX_OUTPUT_TOKENS=700
LEARNING_PANEL_MAX_RETRIEVED_CHUNKS=6
LEARNING_PANEL_MAX_SUMMARY_CHARS=1400
LEARNING_PANEL_COMPACTION_TRIGGER_MESSAGES=12
LEARNING_PANEL_RECENT_CONTEXT_MESSAGES=4

# --- Attribution / cost calibration ---
ATTRIBUTION_CUTOFF_DATE=
ATTRIBUTION_PREDICTOR_LOOKBACK_HOURS=24
ATTRIBUTION_GRADUATION_MIN_PREDICTIONS=10
VITE_ATTRIBUTION_TOP_DECILE_BANNER_ENABLED=true
COST_CALIBRATION_WINDOW_DAYS=28
COST_CALIBRATION_DRIFT_THRESHOLD=20
COST_CALIBRATION_MIN_SAMPLES=50
COST_CALIBRATION_DRIFT_MIN_SAMPLES=200
COST_PREDICTION_HEADROOM_PCT=25
COST_PREDICTION_MIN_HISTORY_DAYS=14
LLM_USAGE_RETENTION_DAYS=90

# --- Auditing ---
AUDIT_POLICY_MIN_REVIEWS=5
AUDIT_PREDICTIONS_PER_CYCLE=
AUDIT_LLM_MODEL=gemma4:26b

# --- E2E / Playwright ---
TEST_USER_EMAIL=testing-team@divinr.ai
TEST_USER_PASSWORD=change-me
PLAYWRIGHT_STORAGE_STATE=apps/e2e/.auth/testing-team.json
E2E_API_BASE=http://127.0.0.1:7100
E2E_LOGIN_EMAIL=demo-user@orchestratorai.io
E2E_LOGIN_PASSWORD=DemoUser123!
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# --- Credentials ---
# Required only for production. Dev uses an insecure fallback if blank.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CREDENTIAL_ENCRYPTION_KEY=
